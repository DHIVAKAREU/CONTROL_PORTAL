# Server Environment Config

# Web Server Port
PORT=5000

# Security (Replace with secure random strings for deployment)
JWT_SECRET="super-secret-key-for-dev-only"

# CORS Configuration (Set to frontend domain in production, e.g., https://tac.app.com)
CORS_ORIGIN="*"

# Frontend Url (Used for links inside emails or system returns)
FRONTEND_URL="http://localhost:3000"

# Database Configuration
DATABASE_URL="database.sqlite"
